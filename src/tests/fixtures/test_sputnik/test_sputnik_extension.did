type AppAsyncQueryArgs = record { value : principal };
type AppAsyncQueryResult = record { value : principal; "text" : text };
type AppCheckEnumsArgs = record {
  status : AppCheckEnumsArgsStatus;
  username : text;
};
type AppCheckEnumsArgsStatus = variant {
  Variant0 : record { owner : principal; "type" : text };
  Variant1 : record { "type" : text };
  Variant2 : record { assignee : principal; "type" : text };
};
type AppCheckEnumsResult = record { status : text };
type AppDemoAntonioArgs = record {
  id : opt principal;
  sub : AppDemoAntonioArgsSub;
};
type AppDemoAntonioArgsSub = record { arr : blob };
type AppDemoAntonioResult = record {
  id : opt principal;
  sub : AppDemoAntonioResultSub;
  world : text;
};
type AppDemoAntonioResultSub = record { arr : opt blob; value : opt nat64 };
type AppReadDocTestArgs = record { key : text; collection : text };
type AppReadDocTestResult = record { value : nat64 };
type AppSetDocTestArgs = record {
  key : text;
  collection : text;
  value : nat64;
};
type AppUpdateArgsOnlyArgs = record { value : text };
type AppWelcomeArgs = record { value : text };
type AppWelcomeResult = record { value : nat64; caller : principal };
service : {
  app_async_query : (AppAsyncQueryArgs) -> (AppAsyncQueryResult) query;
  app_check_caller : () -> ();
  app_check_enums : (AppCheckEnumsArgs) -> (AppCheckEnumsResult);
  app_demo_antonio : (AppDemoAntonioArgs) -> (AppDemoAntonioResult) query;
  app_hello_world : (AppAsyncQueryArgs) -> (AppAsyncQueryResult) query;
  app_query_no_args : () -> (AppAsyncQueryResult) query;
  app_query_no_args_no_result : () -> () query;
  app_read_doc_test : (AppReadDocTestArgs) -> (AppReadDocTestResult) query;
  app_set_doc_test : (AppSetDocTestArgs) -> ();
  app_sync_update : () -> ();
  app_update_args_only : (AppUpdateArgsOnlyArgs) -> ();
  app_welcome : (AppWelcomeArgs) -> (AppWelcomeResult);
  app_welcome_without_args : () -> (AppWelcomeResult);
  app_yolo : () -> ();
}
